# URL of the online-store-server
# Local: http://localhost:8080
# Staging: https://dev-api.reso-store.com
# Production: https://api.reso-store.com
ONLINE_STORE_SERVER_URL=http://localhost:8080

# Allowed client domain URLs, comma separated
CLIENT_DOMAIN_URLS=http://localhost:3000,http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Agentic loop guardrails
MAX_ITERATIONS=20
MAX_TOTAL_TOKENS=200000

# Local Express server port (local dev only)
PORT=3001
